{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/schemas/account.schema.json",
  "title": "Local learning account",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "id", "type", "displayName", "createdAt", "updatedAt"],
  "properties": {
    "schemaVersion": { "const": 1 },
    "id": { "type": "string", "minLength": 1 },
    "type": { "enum": ["guest", "local", "registered"] },
    "displayName": { "type": "string", "minLength": 1, "maxLength": 32 },
    "createdAt": { "type": ["string", "null"], "format": "date-time" },
    "updatedAt": { "type": ["string", "null"], "format": "date-time" }
  }
}
